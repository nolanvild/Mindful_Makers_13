# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real keys.

# --- Supabase (Project Settings -> API) ---
# The project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# The "anon"/"publishable" public key (safe to expose to the browser; RLS protects data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Anthropic (https://console.anthropic.com -> API Keys) ---
# Server-only. Used by /api/identify for plant identification. Never exposed to the client.
ANTHROPIC_API_KEY=

# --- App ---
# Base URL of the deployed app, used for auth magic-link redirects.
# Local dev: http://localhost:3000   Vercel: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
